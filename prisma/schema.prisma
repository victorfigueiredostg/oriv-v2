// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Empreendimento {
  id          Int       @id @default(autoincrement())
  nome        String
  logoUrl     String?   // URL Cloudinary — logo horizontal (topo do formulário)
  iconeUrl    String?   // URL Cloudinary — ícone quadrado (card da landing)
  slug        String    @unique
  ativo       Boolean   @default(true)
  criadoEm    DateTime  @default(now())
  usuarios    Usuario[]
  visitas     Visita[]
}

model Usuario {
  id               Int             @id @default(autoincrement())
  usuario          String          @unique
  senhaHash        String
  role             Role            @default(STAND)
  empreendimentoId Int?
  empreendimento   Empreendimento? @relation(fields: [empreendimentoId], references: [id])
  criadoEm         DateTime        @default(now())
  visitas          Visita[]
}

model Visita {
  id               Int            @id @default(autoincrement())
  empreendimentoId Int
  empreendimento   Empreendimento @relation(fields: [empreendimentoId], references: [id])
  usuarioId        Int
  usuario          Usuario        @relation(fields: [usuarioId], references: [id])
  nomeCliente      String
  idadeCliente     Int?           // idade do lead em anos; nullable p/ não quebrar registros antigos
  telefone         String?        // telefone do lead; opcional (usado tb na verificação no CVCRM)
  comoChegou       ComoChegou
  corretor         String
  imobiliaria      String
  comoSoube        ComoSoube
  cvStatus         String?        // CADASTRADO | NAO_CADASTRADO | NAO_PREENCHEU (verificado no CVCRM ao salvar)
  cvConfirmadoEm   DateTime?      // quando o gestor confirmou o cadastro manual no CV
  salvoEm          DateTime       @default(now())

  @@index([empreendimentoId])
  @@index([salvoEm])
  @@index([corretor])
  @@index([comoSoube])
}

model Imobiliaria {
  id       Int      @id @default(autoincrement())
  nome     String   @unique
  criadoEm DateTime @default(now())
}

// Configurações chave-valor (ex.: credenciais de integração de API)
model Configuracao {
  chave String @id
  valor String
}

enum Role {
  ADMIN
  STAND
}

enum ComoChegou {
  AGENDADO_CORRETOR
  CLIENTE_PASSANTE
}

enum ComoSoube {
  INSTAGRAM
  FACEBOOK
  WHATSAPP
  CORRETOR
  PANFLETO
  TV
  RADIO
  STAND_CENTRAL_VENDAS
  INDICACAO
  OUTDOOR
  OBRA
}
